  "alert_LA001_title": "ಸಾಮೂಹಿಕ ಒಟಿಪಿ ಫಿಶಿಂಗ್ ಅಭಿಯಾನ ಸಕ್ರಿಯವಾಗಿದೆ",
  "alert_LA001_desc": "ಎಚ್‌ಡಿಎಫ್‌ಸಿ ಮತ್ತು ಎಸ್‌ಬಿಐ ಗ್ರಾಹಕರನ್ನು ಗುರಿಯಾಗಿಸಿಕೊಂಡು ಸಂಘಟಿತ ಫಿಶಿಂಗ್ ಅಭಿಯಾನ. ಅಂದಾಜು ೨೦೦೦ ಕ್ಕೂ ಹೆಚ್ಚು ಗುರಿಗಳು.",
  "alert_LA001_evidence": "೨ ಗಂಟೆಗಳಲ್ಲಿ ೪೧೨ ದೂರುಗಳು",
  "alert_LA002_title": "ಗ್ಯಾಂಗ್ ವಾರ್ ಬೆದರಿಕೆ ಗುಪ್ತಚರ ಮಾಹಿತಿ ಸ್ವೀಕರಿಸಲಾಗಿದೆ",
  "alert_LA002_desc": "ಎರಡು ಪ್ರತಿಸ್ಪರ್ಧಿ ಬಣಗಳ ನಡುವೆ ಸಂಘರ್ಷಕ್ಕೆ ಯೋಜನೆ ರೂಪಿಸಿರುವ ಮಾಹಿತಿ. ಸ್ಥಳ: ಸಿರುಗುಪ್ಪ ರಸ್ತೆ ಪ್ರದೇಶ.",
  "alert_LA002_evidence": "ಮಾಹಿತಿದಾರರ ಸುಳಿವು + ಸಿಡಿಆರ್ ವಿಶ್ಲೇಷಣೆ",
  "alert_LA003_title": "₹೪.೨ ಕೋಟಿ ಹವಾಲಾ ವಹಿವಾಟು ಪತ್ತೆ",
  "alert_LA003_desc": "೧೪ ಖಾತೆಗಳಿಗೆ ವ್ಯವಸ್ಥಿತ ಠೇವಣಿಗಳ ಸರಣಿ, ಹವಾಲಾ ಕಾರ್ಯಾಚರಣೆಗೆ ಹೊಂದಿಕೆಯಾಗುವ ಮಾದರಿ.",
  "alert_LA003_evidence": "ಎಫ್‌ಐಯು ಎಚ್ಚರಿಕೆ + ಬ್ಯಾಂಕ್ ವಿಶ್ಲೇಷಣೆ",
  "alert_LA004_title": "ಮಾದಕ ವಸ್ತುಗಳ ರವಾನೆ ಮಾರ್ಗದಲ್ಲಿದೆ — ಎನ್‌ಎಚ್‌೪",
  "alert_LA004_desc": "ಟ್ರಕ್ ಕೆಎ-೨೪-ಎಬಿ-೫೫೮೮ ಮಾದಕ ವಸ್ತು ಸಾಗಿಸುತ್ತಿರುವ ಶಂಕೆ. ಕೊನೆಯದಾಗಿ ಧಾರವಾಡ ಬೈಪಾಸ್ ಬಳಿ ಪತ್ತೆ.",
  "alert_LA004_evidence": "ಮಾಹಿತಿದಾರರ ಸುಳಿವು + ವಾಹನ ಫ್ಲ್ಯಾಗ್",
  "alert_LA005_title": "ಸಿಮ್ ಸ್ವಾಪ್ ವಂಚನೆ ಅಲೆ — ಮೈಸೂರು",
  "alert_LA005_desc": "ವ್ಯಾಪಾರ ಮಾಲೀಕರನ್ನು ಗುರಿಯಾಗಿಸಿಕೊಂಡು ಸಂಘಟಿತ ಸಿಮ್ ಸ್ವಾಪ್ ದಾಳಿಗಳು. ಈಗಾಗಲೇ ₹೬೭ ಲಕ್ಷ ಲೂಟಿ.",
  "alert_LA005_evidence": "೮೯ ಸಂತ್ರಸ್ತರ ದೂರುಗಳು",
  "alert_LA006_title": "ಡಾರ್ಕ್ ವೆಬ್ ಮಾಹಿತಿ ಸೋರಿಕೆ — ಕೆಎ ಪೊಲೀಸ್ ಇಮೇಲ್‌ಗಳು",
  "alert_LA006_desc": "ಡಾರ್ಕ್ ವೆಬ್ ಫೋರಂನಲ್ಲಿ ೨೩ @ksp.gov.in ರುಜುವಾತುಗಳು ಪತ್ತೆ. ತಕ್ಷಣದ ಪಾಸ್‌ವರ್ಡ್ ಮರುಹೊಂದಿಸುವ ಅಗತ್ಯವಿದೆ.",
  "alert_LA006_evidence": "ಡಾರ್ಕ್ ವೆಬ್ ಗುಪ್ತಚರ ಸ್ಕ್ಯಾನ್",
  "alert_LA007_title": "ಕ್ರಿಪ್ಟೋಕರೆನ್ಸಿ ಅಕ್ರಮ ಹಣ ವರ್ಗಾವಣೆ ಶಂಕೆ",
  "alert_LA007_desc": "೬ ವಾಲೆಟ್‌ಗಳಲ್ಲಿ ₹೧.೪ ಕೋಟಿ ಕ್ರಿಪ್ಟೋಗೆ ಪರಿವರ್ತಿಸಲಾಗಿದೆ. ಶಂಕಿತ ಬೆಂಗಳೂರು ನಗರ ಸೈಬರ್ ಅಪರಾಧ ಪ್ರಕರಣಕ್ಕೆ ಲಿಂಕ್ ಆಗಿದ್ದಾನೆ.",
  "alert_LA007_evidence": "ಎಫ್‌ಐಯು ವರದಿ + ಬ್ಲಾಕ್‌ಚೈನ್ ಟ್ರೇಸ್",
  "alert_LA008_title": "ಸಾಮಾಜಿಕ ಮಾಧ್ಯಮಗಳಲ್ಲಿ ಬೆದರಿಕೆ ಪೋಸ್ಟ್‌ಗಳು ಪತ್ತೆ",
  "alert_LA008_desc": "ಪೊಲೀಸ್ ಸಿಬ್ಬಂದಿಯನ್ನು ಗುರಿಯಾಗಿಸಿಕೊಂಡು ೩ ವೇದಿಕೆಗಳಲ್ಲಿ ೧೨ ಬೆದರಿಕೆ ಪೋಸ್ಟ್‌ಗಳು. ಖಾತೆಗಳನ್ನು ಪತ್ತೆ ಮಾಡಲಾಗುತ್ತಿದೆ.",
  "alert_LA008_evidence": "ಓಸಿಂಟ್ ಮಾನಿಟರಿಂಗ್",
  "alert_LA009_title": "ನಕಲಿ ಹೂಡಿಕೆ ಯೋಜನೆ ವೆಬ್‌ಸೈಟ್ ಪತ್ತೆ",
  "alert_LA009_desc": "ಕೃಷಿ ಹೂಡಿಕೆಯ ಮೇಲೆ ೪೦% ಆದಾಯದ ಭರವಸೆ ನೀಡುವ ಡೊಮೇನ್. ೧೫೦ ಸಂತ್ರಸ್ತರು ವರದಿ ಮಾಡಿದ್ದಾರೆ. ಸೈಟ್ ವಿದೇಶದಲ್ಲಿ ಹೋಸ್ಟ್ ಆಗಿದೆ.",
  "alert_LA009_evidence": "ನಾಗರಿಕರ ದೂರು + ವೆಬ್‌ಸೈಟ್ ವಿಶ್ಲೇಷಣೆ",
  "alert_LA010_title": "ಮಾದಕ ವಸ್ತು ವ್ಯಸನದ ಹಾಟ್‌ಸ್ಪಾಟ್ ವರದಿ",
  "alert_LA010_desc": "ಗೋಕುಲ್ ರಸ್ತೆ ಪ್ರದೇಶದಲ್ಲಿ ೩ ಹೊಸ ಮಾದಕ ವಸ್ತು ವ್ಯಸನದ ತಾಣಗಳು ಪತ್ತೆ. ವ್ಯಸನಮುಕ್ತಿ ಹಸ್ತಕ್ಷೇಪದ ಅಗತ್ಯವಿದೆ.",
